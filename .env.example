# ============================================================
# WhatsApp Reply Agent - Environment Configuration
# ============================================================

# --- LLM ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=models/text-embedding-004

# --- User identity (you) ---
USER_NAME=Ankit
USER_PHONE=+919999999999
USER_PERSONA_FILE=persona.md

# --- Agent behavior ---
# If true, agent sends replies automatically.
# If false (recommended at start), replies are queued as drafts you approve.
AUTO_SEND=false

# Confidence threshold (0-1). Below this, always queue as draft even if AUTO_SEND=true.
AUTO_SEND_CONFIDENCE_THRESHOLD=0.85

# Always queue replies as drafts for these contacts (comma-separated phone numbers)
ALWAYS_DRAFT_CONTACTS=

# Never reply to these contacts (escalate to you instead)
NEVER_REPLY_CONTACTS=

# --- Storage ---
SQLITE_PATH=./data/memory.db
CHROMA_PATH=./data/chroma
SHORT_TERM_WINDOW=15

# --- WhatsApp connector ---
# Options: "twilio" | "bridge"
WHATSAPP_PROVIDER=bridge

# Twilio (if WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Bridge (if WHATSAPP_PROVIDER=bridge) - URL of your whatsapp-web.js Node bridge
BRIDGE_SEND_URL=http://localhost:3000/send
BRIDGE_AUTH_TOKEN=change_me

# --- Server ---
HOST=0.0.0.0
PORT=8000
WEBHOOK_SECRET=change_me_to_something_random
